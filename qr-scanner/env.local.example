# ─── QR Encryption (harus IDENTIK dengan konstanta di qr_service.dart) ───────
#
# Di Flutter (qr_service.dart):
#   const String _aesKeyHex = '0123456789abcdef0123456789abcdef'; ← salin ke sini
#   const String _aesIvHex  = 'abcdef9876543210';                ← salin ke sini
#
# ⚠️  Key = 32 karakter UTF8 (256-bit AES)
# ⚠️  IV  = 16 karakter UTF8 (128-bit)
# ⚠️  JANGAN commit file ini ke git!

QR_AES_KEY=0123456789abcdef0123456789abcdef
QR_AES_IV=abcdef9876543210
